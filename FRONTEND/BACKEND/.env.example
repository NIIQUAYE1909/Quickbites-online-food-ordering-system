# =============================================
# QuickBite - Environment Variables for Render
# =============================================
# Copy this to .env and fill in your values
# NOTE: Render auto-sets DB_URL, DB_USER, DB_PASSWORD
# from the MySQL service - you don't need to set these manually!
# =============================================

# Database connection (Render sets these automatically via render.yaml)
# Format: mysql://username:password@hostname:port/database
DB_URL=mysql://username:password@host:3306/quickbite_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Server port (Render sets this automatically)
PORT=8080

# =============================================
# Frontend API URL
# =============================================
# Set this in the Frontend static site environment variables
API_URL=https://quickbite-backend.onrender.com/api
